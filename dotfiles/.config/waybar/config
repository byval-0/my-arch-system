{
"layer": "top",
"position": "top",
"height": 24,
"margin-bottom":0,
"margin-top":0,

// "modules-left": ["sway/mode","hyprland/window","mpd"],
// "modules-center": ["sway/workspaces","hyprland/workspaces"],
// "modules-right":  ["tray", "cava", "pulseaudio","network","hyprland/language","clock"],
"modules-left": ["hyprland/workspaces","custom/ScrollMPRIS"],
"modules-center": [],
"modules-right":  ["tray", "cava", "pulseaudio","hyprland/language","network","clock"],

"custom/ScrollMPRIS": {
    "return-type": "json",
    "exec": "ScrollMPRIS",
    "escape": true,
    "on-click": "playerctl play-pause"
},

"hyprland/workspaces": {
     "sort-by-name": true,
     "on-click": "activate"
},
"hyprland/window": {
    "max-length": 200,
    "separate-outputs": true
},
"hyprland/language": {
    "format": "ґ░ММ {}",
    "format-en": "EN",
    "format-th": "TH",
},
"cava": {
        "cava_config": "/home/byval/.config/cava/config_raw",
        "framerate": 30,
        "input_delay": 2,
        "format-icons": ["тЦБ", "тЦВ", "тЦГ", "тЦД", "тЦЕ", "тЦЖ", "тЦЗ", "тЦИ" ],
        "actions": {
                   "on-click-right": "mode"
         }
},
"sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
},
"tray": {
    "icon-size": 16,
    "spacing": 6
},
"clock": {
    "locale": "C",
    "interval": 1,
    "format": "яАЧ {:%D %H:%M:%S}",
    "format-alt": "яБ│ {:%a %d, %b %Y, %H:%M:%S}", // Icon: calendar-alt
    //"tooltip-format": "<tt><small>{calendar}</small></tt>",
    "tooltip-format": "{:%a %d, %b %Y}\n<span font='DroidSansM Nerd Font'>{calendar}</span>",
    "calendar": {
                    "mode"          : "month",
                    "on-scroll"     : 1,
                    "format": {
                              "months":     "<span color='#ffead3'><b>{}</b></span>",
                              "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                              "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                              "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                              "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
                              }
                    },
        "actions":  {
                    "on-click-right": "mode",
                    "on-scroll-up": "tz_up",
                    "on-scroll-down": "tz_down",
                    "on-scroll-up": "shift_up",
                    "on-scroll-down": "shift_down"
                    }
},
"cpu": {
    "format": "яЛЫ&#8239;  {usage}%",
    "tooltip": false,
    "on-click": "kitty -e 'btop'"
},
"memory": {
    "interval": 30,
    "format": "яГЙ {used:0.2f}GB",
    "max-length": 10,
    "tooltip": false,
    "warning": 70,
    "critical": 90
},
"network": {
  "interval": 2,
  "format-wifi": "яЗл {signalStrength}%",
  "format-ethernet": "ґ░ИА Ethernet",
  "tooltip-format-ethernet": "{ifname}: {ipaddr}",
  "format-linked": " {ipaddr}",
  "format-disconnected": "яБ▒ Disconnected",
  "format-disabled": "",
  "tooltip": true,
  "max-length": 20,
  "min-length": 6,
  "format-alt": "{essid}",
},
"idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
        "activated": "яБо",
        "deactivated": "яБ░"
    }
},
"pulseaudio": {
  // "scroll-step": 1, // %, can be a float
  "format": "{icon} {volume}% {format_source}",
  "format-bluetooth": "{icon}яКФ {volume}% {format_source}",
  "format-bluetooth-muted": "яСж {format_source}",
  "format-muted": "яСж  {format_source}",
  "format-source": "яД░ {volume}%",
  "format-source-muted": "яД▒",
  "format-icons": {
    "headphone": "яАе",
    "hands-free": "яЦР",
    "headset": "ЁЯОз",
    "phone": "яВХ",
    "portable": "яВХ",
    "car": "яЖ╣",
    "default": ["яАж", "яАз", "яАи"]
  },
  "on-click": "pavucontrol"
},
"mpd": {
  "format": "{stateIcon} {artist} - {title}",
  "format-disconnected": "ЁЯО╢",
  "format-stopped": "тЩк",
  "interval": 10,
  "consume-icons": {
    "on": "яГД " // Icon shows only when "consume" is on
  },
  "random-icons": {
    "off": "<span color=\"#f53c3c\">яБ┤</span> ", // Icon grayed out when "random" is off
    "on": "яБ┤ "
  },
  "repeat-icons": {
    "on": "яАЮ "
  },
  "single-icons": {
    "on": "яАЮ1 "
  },
  "state-icons": {
    "paused": "яБМ",
    "playing": "яБЛ"
  },
  "tooltip-format": "MPD (connected)",
  "tooltip-format-disconnected": "MPD (disconnected)",
  "max-length": 35
},
"custom/recorder": {
    "format": "яА╜ Rec",
    "format-disabled": "яА╜ Off-air", //An empty format will hide the module.
    "return-type": "json",
    "interval": 1,
    "exec": "echo '{\"class\": \"recording\"}'",
    "exec-if": "pgrep wf-recorder",
},
"custom/audiorec": {
    "format": "тЩм Rec",
    "format-disabled": "тЩм Off-air", //An empty format will hide the module.
    "return-type": "json",
    "interval": 1,
    "exec": "echo '{\"class\": \"audio recording\"}'",
    "exec-if": "pgrep ffmpeg",
},
}
